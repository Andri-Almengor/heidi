NODE_ENV=development
PORT=3000

# URL /exec del despliegue de Google Apps Script
APPS_SCRIPT_URL=https://script.google.com/macros/s/REEMPLAZAR/exec

# Clave devuelta por setupProject(). Nunca se expone al frontend.
APPS_SCRIPT_API_KEY=REEMPLAZAR

# Orígenes separados por coma. Use * únicamente durante desarrollo local.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Tiempo máximo para esperar una respuesta de Apps Script.
APPS_SCRIPT_TIMEOUT_MS=25000

# En Render/Railway/Cloud Run normalmente debe ser 1.
TRUST_PROXY=0
