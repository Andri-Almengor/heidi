{
  "name": "heidi-quiz-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Backend Node.js y Express para Heidi Quiz, conectado a Google Apps Script y Google Sheets.",
  "main": "src/server.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "node --watch src/server.js",
